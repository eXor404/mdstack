---
import { getCollection, render } from 'astro:content';
import Doc from '../layouts/Doc.astro';

const all = await getCollection('docs');
const custom = all.find((e) => e.id === '404');

let CustomContent: any = null;
let customHeadings: any[] = [];
let title = '404 — Not found';

if (custom) {
  const r = await render(custom);
  CustomContent = r.Content;
  customHeadings = r.headings;
  title = custom.data.title ?? '404';
}
---
{custom ? (
  <Doc title={title} currentId="404" headings={customHeadings}>
    <CustomContent />
  </Doc>
) : (
  <Doc title={title} currentId="404" headings={[]} hideToc={true}>
    <div class="not-found">
      <p class="not-found-code">404</p>
      <p class="not-found-text">This page doesn’t exist.</p>
      <a class="not-found-home" href="/">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        Back home
      </a>
    </div>
  </Doc>
)}
