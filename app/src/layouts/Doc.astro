---
import { getCollection } from 'astro:content';
import '~theme';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  currentId: string;
  headings: Heading[];
}

const { title, currentId, headings } = Astro.props;

const all = await getCollection('docs');

const pages = all
  .filter((e) => e.id !== 'footer')
  .map((e) => ({
    id: e.id,
    title: e.data.title ?? e.id,
    order: e.data.order ?? Number.POSITIVE_INFINITY,
    href: e.id === 'index' ? '/' : `/${e.id}/`,
  }))
  .sort((a, b) => {
    if (a.order !== b.order) return a.order - b.order;
    return a.title.localeCompare(b.title);
  });

// Group H3s under their preceding H2.
type TocGroup = Heading & { children: Heading[] };
const tocGroups: TocGroup[] = [];
for (const h of headings) {
  if (h.depth === 2) {
    tocGroups.push({ ...h, children: [] });
  } else if (h.depth === 3 && tocGroups.length > 0) {
    tocGroups[tocGroups.length - 1].children.push(h);
  }
}

// Parse optional footer.md into columns.
// Format: each `## Title` starts a column; bullet links become its items.
type FooterCol = { title: string; items: { label: string; href: string }[] };
function parseFooterColumns(body: string): FooterCol[] {
  const sections = body.split(/^##\s+/m).slice(1);
  return sections.map((sec) => {
    const lines = sec.split('\n');
    const title = (lines.shift() ?? '').trim();
    const items: FooterCol['items'] = [];
    for (const line of lines) {
      const m = line.match(/^\s*-\s*\[([^\]]+)\]\(([^)]+)\)/);
      if (m) items.push({ label: m[1].trim(), href: m[2].trim() });
    }
    return { title, items };
  }).filter((c) => c.title && c.items.length > 0);
}
const footerEntry = all.find((e) => e.id === 'footer');
const hasFooterMd = !!footerEntry;
const footerColumns: FooterCol[] = footerEntry?.body ? parseFooterColumns(footerEntry.body) : [];

// If footer.md exists, its columns replace the auto Pages column entirely.
// Otherwise we show the Pages column. Columns render right-to-left
// (first defined = rightmost), so reverse before rendering.
const pagesColumn: FooterCol = {
  title: 'Pages',
  items: pages.map((p) => ({ label: p.title, href: p.href })),
};
const visibleColumns: FooterCol[] = hasFooterMd ? footerColumns : [pagesColumn];
const renderedColumns: FooterCol[] = [...visibleColumns].reverse();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <header class="header">
      <div class="header-inner">
        <a class="brand" href="/">
          <span class="brand-mark" aria-hidden="true"></span>
          <span>mdstack</span>
        </a>
        <nav class="page-nav" aria-label="Pages">
          {pages.map((p) => (
            <a href={p.href} aria-current={p.id === currentId ? 'page' : undefined}>
              {p.title}
            </a>
          ))}
        </nav>
        <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
          </svg>
        </button>
      </div>
    </header>

    <div class="layout">
      <aside class="toc" aria-label="On this page">
        <p class="toc-title">On this page</p>
        {tocGroups.length === 0 ? (
          <p class="toc-empty">No sections</p>
        ) : (
          <ul class="toc-list">
            {tocGroups.map((g) => (
              <li class="toc-group">
                <div class="toc-row">
                  <a href={`#${g.slug}`} data-toc-link={g.slug}>{g.text}</a>
                  {g.children.length > 0 && (
                    <button class="toc-chev" aria-label="Toggle subsections" data-toc-toggle>
                      <svg width="10" height="10" viewBox="0 0 10 10" fill="currentColor" aria-hidden="true">
                        <path d="M1 3 L5 7 L9 3 Z" />
                      </svg>
                    </button>
                  )}
                </div>
                {g.children.length > 0 && (
                  <ul class="toc-sub">
                    {g.children.map((c) => (
                      <li>
                        <div class="toc-row">
                          <a href={`#${c.slug}`} data-toc-link={c.slug}>{c.text}</a>
                        </div>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            ))}
          </ul>
        )}
      </aside>

      <main class="content">
        <slot />
      </main>
    </div>

    <footer class="footer">
      <div class="footer-inner">
        <div class="footer-cols">
          {renderedColumns.map((col) => (
            <div class="footer-col">
              <h4>{col.title}</h4>
              <ul>
                {col.items.map((it) => (
                  <li><a href={it.href}>{it.label}</a></li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
      <div class="footer-bottom">
        Made with <span class="footer-heart">❤</span> with
        <span class="footer-brand-inline">
          <span class="brand-mark" aria-hidden="true"></span>
          <span>mdstack</span>
        </span>
        <span class="footer-sep">|</span>
        eXor404
      </div>
    </footer>

    <script is:inline>
      // Theme toggle (light/dark)
      (() => {
        const root = document.documentElement;
        const stored = localStorage.getItem('mdstack-theme');
        if (stored === 'light') root.setAttribute('data-theme', 'light');
        const btn = document.getElementById('theme-toggle');
        if (btn) {
          btn.addEventListener('click', () => {
            const next = root.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
            if (next === 'dark') root.removeAttribute('data-theme');
            else root.setAttribute('data-theme', 'light');
            localStorage.setItem('mdstack-theme', next);
          });
        }
      })();

      // Collapsible TOC groups
      (() => {
        document.querySelectorAll('[data-toc-toggle]').forEach((btn) => {
          btn.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            const group = btn.closest('.toc-group');
            if (group) group.classList.toggle('collapsed');
          });
        });
      })();

      // Copy button on code blocks
      (() => {
        const COPY_SVG = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
        const CHECK_SVG = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>';
        document.querySelectorAll('main.content pre').forEach((pre) => {
          if (pre.querySelector('.copy-btn')) return;
          const btn = document.createElement('button');
          btn.className = 'copy-btn';
          btn.type = 'button';
          btn.setAttribute('aria-label', 'Copy code');
          btn.innerHTML = COPY_SVG;
          btn.addEventListener('click', async () => {
            const code = pre.querySelector('code');
            const text = (code ? code.innerText : pre.innerText).replace(/\n$/, '');
            try {
              await navigator.clipboard.writeText(text);
              btn.classList.add('copied');
              btn.innerHTML = CHECK_SVG;
              setTimeout(() => {
                btn.classList.remove('copied');
                btn.innerHTML = COPY_SVG;
              }, 1500);
            } catch {}
          });
          pre.appendChild(btn);
        });
      })();

      // Scroll-spy for TOC
      (() => {
        const links = Array.from(document.querySelectorAll('[data-toc-link]'));
        if (links.length === 0) return;
        const map = new Map(links.map((a) => [a.dataset.tocLink, a]));
        const headings = links
          .map((a) => document.getElementById(a.dataset.tocLink))
          .filter(Boolean);
        if (headings.length === 0) return;

        let active = null;
        const setActive = (slug) => {
          if (active === slug) return;
          links.forEach((a) => a.classList.remove('active'));
          if (slug && map.has(slug)) map.get(slug).classList.add('active');
          active = slug;
        };

        const observer = new IntersectionObserver(
          (entries) => {
            const visible = entries
              .filter((e) => e.isIntersecting)
              .sort((a, b) => a.target.offsetTop - b.target.offsetTop);
            if (visible.length > 0) {
              setActive(visible[0].target.id);
            }
          },
          { rootMargin: '-80px 0px -70% 0px', threshold: 0 }
        );
        headings.forEach((h) => observer.observe(h));
      })();
    </script>
  </body>
</html>
