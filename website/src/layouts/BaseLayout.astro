---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getNpmVersion } from '../lib/version';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'mdstack',
  description = 'Zero-config static-site CLI for markdown. Dev server, builds, four themes, deploy anywhere static.',
  ogImage = '/og-image.svg',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://mdstack.dev').toString();
const version = getNpmVersion();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'mdstack',
  description,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Node.js 18+',
  url: canonical,
  sameAs: [
    'https://github.com/eXor404/mdstack',
    'https://www.npmjs.com/package/@exor404/mdstack',
  ],
  softwareVersion: version,
  license: 'https://opensource.org/licenses/MIT',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  author: {
    '@type': 'Person',
    name: 'eXor404',
    url: 'https://github.com/eXor404',
  },
};
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="dark light" />
    <meta name="theme-color" content="#0d0d0d" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preload" href="/fonts/Inter.var.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/JetBrainsMono.var.woff2" as="font" type="font/woff2" crossorigin />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, Astro.site ?? 'https://mdstack.dev').toString()} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site ?? 'https://mdstack.dev').toString()} />

    <script is:inline>
      // Apply persisted theme before paint to avoid flash.
      (function () {
        try {
          var stored = localStorage.getItem('mdstack-site-theme');
          var theme = stored === 'light' || stored === 'dark'
            ? stored
            : (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
          document.documentElement.dataset.theme = theme;
        } catch (e) {}
      })();
    </script>

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      import '../scripts/theme-toggle.ts';
      import '../scripts/copy-button.ts';
      import '../scripts/reveal.ts';
    </script>
  </body>
</html>
