---
import Copy from './icons/Copy.astro';
import Check from './icons/Check.astro';

interface InstallTab {
  id: string;
  label: string;
  /** Lines as plain strings — `$ ` prefix for prompts is added in render. */
  lines: string[];
  /** What the copy button puts on the clipboard (no `$ `). */
  copy: string;
}

interface Props {
  tabs: InstallTab[];
  variant?: 'hero' | 'plain';
  initial?: string;
  showTabs?: boolean;
  id?: string;
}

const {
  tabs,
  variant = 'hero',
  initial = tabs[0]?.id,
  showTabs = true,
  id,
} = Astro.props;

const cardId = id ?? `install-card-${Math.random().toString(36).slice(2, 8)}`;
---

<div
  class:list={['install-card', `install-card--${variant}`]}
  id={cardId}
  data-install-card
>
  {showTabs && (
    <div class="install-tabs" role="tablist" aria-label="Install method">
      {tabs.map((tab) => (
        <button
          type="button"
          role="tab"
          class="install-tab"
          aria-selected={tab.id === initial ? 'true' : 'false'}
          aria-controls={`${cardId}-panel`}
          data-install-tab={tab.id}
          tabindex={tab.id === initial ? 0 : -1}
        >
          {tab.label}
        </button>
      ))}
    </div>
  )}

  <div class="install-frame">
    <div class="terminal-chrome" aria-hidden="true">
      <span class="dot dot-r"></span>
      <span class="dot dot-y"></span>
      <span class="dot dot-g"></span>
      <span class="terminal-label">TERMINAL</span>
      <span class="chrome-spacer"></span>
      <button
        type="button"
        class="copy-btn"
        data-copy={tabs.find((t) => t.id === initial)?.copy ?? ''}
        data-copy-label="Copy command"
        aria-label="Copy command"
      >
        <span class="copy-icon copy-icon--default"><Copy size={14} /></span>
        <span class="copy-icon copy-icon--copied"><Check size={14} /></span>
      </button>
    </div>

    <div class="install-panel" role="tabpanel" id={`${cardId}-panel`}>
      {tabs.map((tab) => (
        <pre
          class="install-pre"
          data-install-panel={tab.id}
          hidden={tab.id !== initial ? true : undefined}
        ><code>{tab.lines.map((line, i) => (
          <span class="install-line">
            <span class="install-prompt">$</span>
            <span class="install-cmd">{line}</span>
          </span>
        ))}</code></pre>
      ))}
    </div>
  </div>
</div>

<style>
  .install-card {
    width: 100%;
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .install-tabs {
    display: inline-flex;
    align-self: center;
    gap: 2px;
    padding: 4px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
  }
  .install-tab {
    padding: 6px 12px;
    background: transparent;
    border: 0;
    border-radius: 7px;
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--text-muted);
    cursor: pointer;
    transition: color var(--t-fast), background-color var(--t-fast);
  }
  .install-tab:hover { color: var(--text); }
  .install-tab[aria-selected='true'] {
    color: var(--text);
    background: var(--surface-2);
    box-shadow: inset 0 0 0 1px var(--border-strong);
  }

  .install-frame {
    position: relative;
    border-radius: 12px;
    background:
      linear-gradient(var(--code-block-bg), var(--code-block-bg)) padding-box,
      var(--grad) border-box;
    border: 1px solid transparent;
    overflow: hidden;
  }
  .install-card--hero .install-frame {
    box-shadow: 0 24px 80px -24px rgba(255, 69, 0, 0.35);
  }

  .terminal-chrome {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 12px;
    border-bottom: 1px solid var(--border);
  }
  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .dot-r { background: #ff5f56; }
  .dot-y { background: #ffbd2e; }
  .dot-g { background: #27c93f; }
  .terminal-label {
    margin-left: 8px;
    font-family: var(--mono);
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--text-dim);
  }
  .chrome-spacer { flex: 1; }

  .copy-btn {
    display: inline-grid;
    place-items: center;
    width: 28px;
    height: 28px;
    background: transparent;
    border: 1px solid transparent;
    border-radius: 6px;
    color: var(--text-muted);
    transition: color var(--t-fast), background-color var(--t-fast), border-color var(--t-fast);
    position: relative;
  }
  .copy-btn:hover { color: var(--text); background: var(--surface-2); border-color: var(--border); }
  .copy-icon { grid-area: 1 / 1; transition: opacity var(--t-fast), transform var(--t-fast); }
  .copy-icon--copied { opacity: 0; transform: scale(0.7); color: var(--accent-green); }
  .copy-btn.is-copied { color: var(--accent-green); border-color: color-mix(in srgb, var(--accent-green) 50%, var(--border)); }
  .copy-btn.is-copied .copy-icon--default { opacity: 0; transform: scale(0.7); }
  .copy-btn.is-copied .copy-icon--copied { opacity: 1; transform: scale(1); }

  .install-panel { position: relative; }
  .install-pre {
    margin: 0;
    padding: 18px 20px 22px;
    font-family: var(--mono);
    font-size: 14px;
    line-height: 1.7;
    color: var(--text);
    background: transparent;
    overflow-x: auto;
  }
  .install-pre[hidden] { display: none; }
  .install-line {
    display: flex;
    gap: 12px;
    align-items: baseline;
  }
  .install-prompt {
    color: var(--text-dim);
    user-select: none;
    -webkit-user-select: none;
    flex-shrink: 0;
  }
  .install-cmd {
    color: var(--text);
    word-break: break-word;
  }

  @media (max-width: 640px) {
    .install-pre { font-size: 13px; padding: 16px 16px 18px; }
    .install-tabs { flex-wrap: wrap; justify-content: center; }
  }
</style>
