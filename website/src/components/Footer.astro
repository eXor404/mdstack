---
import Logo from './Logo.astro';
import { REPO_URL, NPM_URL, RELEASES_URL, LICENSE_URL, AUTHOR_URL, DOCS_URL } from '../lib/links';
---

<footer class="footer">
  <div class="footer-inner" data-reveal>
    <div class="footer-top">
      <div class="footer-brand">
        <div class="footer-brand-row">
          <Logo size={28} />
          <span>mdstack</span>
        </div>
        <p class="footer-tag">Drop a folder of markdown. Get a site.</p>
      </div>

      <div class="footer-cols">
        <div class="footer-col">
          <h4>Project</h4>
          <ul>
            <li><a href={DOCS_URL} target="_blank" rel="noopener">Docs</a></li>
            <li><a href={REPO_URL} target="_blank" rel="noopener">GitHub</a></li>
            <li><a href={NPM_URL} target="_blank" rel="noopener">npm</a></li>
            <li><a href={RELEASES_URL} target="_blank" rel="noopener">Releases</a></li>
            <li><a href={LICENSE_URL} target="_blank" rel="noopener">License</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Themes</h4>
          <ul>
            <li><a href="#themes" data-theme-link="angular">Angular</a></li>
            <li><a href="#themes" data-theme-link="vue">Vue</a></li>
            <li><a href="#themes" data-theme-link="nuxt">Nuxt</a></li>
            <li><a href="#themes" data-theme-link="homebrew">Homebrew</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Made by</h4>
          <ul>
            <li><a href={AUTHOR_URL} target="_blank" rel="noopener">@eXor404</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <span>mdstack</span>
      <span class="footer-sep">·</span>
      <span>MIT</span>
      <span class="footer-sep">·</span>
      <span>made with <span class="footer-heart" aria-hidden="true">♥</span><span class="visually-hidden"> love</span> by <a class="footer-author" href={AUTHOR_URL} target="_blank" rel="noopener">eXor404</a></span>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    background: var(--bg-2);
    padding: 64px 24px 28px;
    margin-top: 96px;
    transition: background-color var(--t-theme), border-color var(--t-theme);
  }
  .footer-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }
  .footer-top {
    display: grid;
    grid-template-columns: minmax(220px, 1fr) auto;
    gap: 64px;
    align-items: start;
  }
  .footer-brand-row {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 700;
    font-size: 16px;
    color: var(--text);
  }
  .footer-tag {
    margin-top: 14px;
    font-size: 14px;
    color: var(--text-muted);
    max-width: 240px;
    line-height: 1.55;
  }
  .footer-cols {
    display: flex;
    gap: 64px;
  }
  .footer-col h4 {
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--text);
    margin-bottom: 14px;
  }
  .footer-col ul { list-style: none; padding: 0; margin: 0; }
  .footer-col li { margin-bottom: 8px; }
  .footer-col a, .footer-col span {
    font-size: 13.5px;
    color: var(--text-muted);
    transition: color var(--t-fast);
  }
  .footer-col a:hover { color: var(--text); }

  .footer-bottom {
    padding-top: 24px;
    border-top: 1px solid var(--border);
    font-size: 13px;
    color: var(--text-dim);
    text-align: center;
  }
  .footer-heart {
    background: var(--grad);
    background-clip: text; -webkit-background-clip: text;
    color: transparent;
    font-weight: 800;
    margin: 0 2px;
  }
  .footer-sep { margin: 0 10px; opacity: 0.6; }
  .footer-author {
    color: var(--text-muted);
    border-bottom: 1px solid var(--border-strong);
    transition: color var(--t-fast), border-color var(--t-fast);
  }
  .footer-author:hover { color: var(--text); border-bottom-color: var(--text-muted); }

  .visually-hidden {
    position: absolute; width: 1px; height: 1px;
    padding: 0; margin: -1px; overflow: hidden;
    clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0;
  }

  @media (max-width: 880px) {
    .footer { padding: 48px 16px 24px; }
    .footer-top { grid-template-columns: 1fr; gap: 32px; }
    .footer-cols { gap: 32px; flex-wrap: wrap; }
    .footer-col { min-width: 130px; }
  }
</style>
