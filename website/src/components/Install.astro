---
import Copy from './icons/Copy.astro';
import Check from './icons/Check.astro';

const installRows = [
  { tag: 'npx',    cmd: 'npx @exor404/mdstack ./docs' },
  { tag: 'npm',    cmd: 'npm i -D @exor404/mdstack' },
  { tag: 'pnpm',   cmd: 'pnpm add -D @exor404/mdstack' },
  { tag: 'yarn',   cmd: 'yarn add -D @exor404/mdstack' },
  { tag: 'global', cmd: 'npm i -g @exor404/mdstack' },
];

const quickStart = [
  { cmd: 'mdstack ./docs',         comment: 'dev server with HMR' },
  { cmd: 'mdstack build ./docs',   comment: 'static build → ./docs/dist/' },
  { cmd: 'mdstack preview ./docs', comment: 'serve the built dist/' },
];
---

<section id="install" class="install">
  <div class="container">
    <div class="section-head" data-reveal>
      <p class="eyebrow">Install</p>
      <h2>Pick your package manager.</h2>
      <p>Five ways to get mdstack on your machine. The CLI binary is always called <code>mdstack</code>.</p>
    </div>

    <div class="install-layout">
      <div class="install-col" data-reveal>
        <h3 class="install-col-h">Install</h3>

        <div class="terminal">
          <div class="terminal-chrome" aria-hidden="true">
            <span class="dot dot-r"></span>
            <span class="dot dot-y"></span>
            <span class="dot dot-g"></span>
            <span class="terminal-label">INSTALL</span>
          </div>
          <ul class="install-list">
            {installRows.map((row) => (
              <li class="install-row">
                <span class="install-prompt" aria-hidden="true">$</span>
                <code class="install-cmd">{row.cmd}</code>
                <span class="install-tag">{row.tag}</span>
                <button
                  type="button"
                  class="copy-btn copy-btn--row"
                  data-copy={row.cmd}
                  data-copy-label={`Copy ${row.tag} command`}
                  aria-label={`Copy ${row.tag} command`}
                >
                  <span class="copy-icon copy-icon--default"><Copy size={14} /></span>
                  <span class="copy-icon copy-icon--copied"><Check size={14} /></span>
                </button>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <div class="install-col" data-reveal style="--reveal-delay:100ms">
        <h3 class="install-col-h">Quick start</h3>

        <div class="terminal terminal--accent">
          <div class="terminal-chrome" aria-hidden="true">
            <span class="dot dot-r"></span>
            <span class="dot dot-y"></span>
            <span class="dot dot-g"></span>
            <span class="terminal-label">RUN</span>
          </div>
          <ul class="qs-list">
            {quickStart.map((row) => (
              <li class="qs-row">
                <span class="qs-prompt" aria-hidden="true">$</span>
                <code class="qs-cmd">{row.cmd}</code>
                <span class="qs-comment"># {row.comment}</span>
              </li>
            ))}
          </ul>
        </div>

        <aside class="callout callout--note">
          <p class="callout-title">
            <span class="callout-icon" aria-hidden="true">
              <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor"><path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8Zm8-6.5a6.5 6.5 0 1 0 0 13 6.5 6.5 0 0 0 0-13ZM6.5 7.75A.75.75 0 0 1 7.25 7h1a.75.75 0 0 1 .75.75v2.75h.25a.75.75 0 0 1 0 1.5h-2a.75.75 0 0 1 0-1.5h.25v-2h-.25a.75.75 0 0 1-.75-.75ZM8 6a1 1 0 1 1 0-2 1 1 0 0 1 0 2Z"/></svg>
            </span>
            Note
          </p>
          <p>
            On first run, mdstack drops a <code>mdstack.config.js</code> and a starter
            <code>index.md</code> into your folder so you have a working homepage immediately.
          </p>
        </aside>
      </div>
    </div>
  </div>
</section>

<style>
  .install-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    align-items: start;
  }
  .install-col-h {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin: 0 0 12px;
  }

  /* Shared terminal frame */
  .terminal {
    border-radius: 12px;
    border: 1px solid var(--border-strong);
    background: var(--code-block-bg);
    overflow: hidden;
  }
  .terminal--accent {
    border: 1px solid transparent;
    background:
      linear-gradient(var(--code-block-bg), var(--code-block-bg)) padding-box,
      var(--grad) border-box;
  }
  .terminal-chrome {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    border-bottom: 1px solid var(--border);
    background: color-mix(in srgb, var(--surface) 70%, transparent);
  }
  .terminal-chrome .dot {
    width: 12px; height: 12px; border-radius: 50%; flex-shrink: 0;
  }
  .terminal-chrome .dot-r { background: #ff5f56; }
  .terminal-chrome .dot-y { background: #ffbd2e; }
  .terminal-chrome .dot-g { background: #27c93f; }
  .terminal-chrome .terminal-label {
    margin-left: 6px;
    font-family: var(--mono);
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.16em;
    color: var(--text-dim);
  }

  /* Install list rows */
  .install-list {
    list-style: none;
    padding: 6px;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .install-row {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    align-items: center;
    gap: 12px;
    padding: 10px 10px 10px 14px;
    border-radius: 8px;
    transition: background var(--t-fast);
  }
  .install-row:hover { background: color-mix(in srgb, var(--surface) 60%, transparent); }
  .install-prompt {
    font-family: var(--mono);
    font-size: 14px;
    color: var(--text-dim);
    user-select: none;
    -webkit-user-select: none;
  }
  .install-cmd {
    font-family: var(--mono);
    font-size: 13.5px;
    color: var(--text);
    background: transparent;
    padding: 0;
    overflow-x: auto;
    white-space: nowrap;
    min-width: 0;
  }
  .install-tag {
    font-family: var(--mono);
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-dim);
    padding: 3px 8px;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: color-mix(in srgb, var(--surface) 70%, transparent);
    flex-shrink: 0;
  }

  .copy-btn--row {
    display: inline-grid;
    place-items: center;
    width: 28px;
    height: 28px;
    border-radius: 7px;
    background: transparent;
    border: 1px solid transparent;
    color: var(--text-muted);
    transition: color var(--t-fast), background var(--t-fast), border-color var(--t-fast);
  }
  .copy-btn--row:hover { color: var(--text); background: var(--surface); border-color: var(--border-strong); }
  .copy-btn--row .copy-icon { grid-area: 1 / 1; transition: opacity var(--t-fast), transform var(--t-fast); }
  .copy-btn--row .copy-icon--copied { opacity: 0; transform: scale(0.7); color: var(--accent-green); }
  .copy-btn--row.is-copied { color: var(--accent-green); border-color: color-mix(in srgb, var(--accent-green) 50%, var(--border)); }
  .copy-btn--row.is-copied .copy-icon--default { opacity: 0; transform: scale(0.7); }
  .copy-btn--row.is-copied .copy-icon--copied { opacity: 1; transform: scale(1); }

  /* Quick start rows */
  .qs-list {
    list-style: none;
    padding: 12px 14px 14px;
    margin: 0;
    display: grid;
    grid-template-columns: auto auto 1fr;
    column-gap: 12px;
    row-gap: 4px;
    font-family: var(--mono);
    font-size: 13.5px;
    line-height: 1.7;
  }
  .qs-row { display: contents; }
  .qs-prompt { color: var(--text-dim); user-select: none; -webkit-user-select: none; }
  .qs-cmd { color: var(--text); white-space: nowrap; background: transparent; padding: 0; }
  .qs-comment { color: var(--text-dim); font-style: italic; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  .callout {
    margin-top: 16px;
    padding: 14px 18px;
    border-left: 3px solid var(--accent-blue);
    background: color-mix(in srgb, var(--accent-blue) 8%, var(--surface));
    border-radius: 8px;
    color: var(--text);
  }
  .callout-title {
    display: flex;
    align-items: center;
    gap: 8px;
    margin: 0 0 6px;
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent-blue);
  }
  .callout-icon { display: inline-flex; align-items: center; }
  .callout p:last-child { margin-bottom: 0; font-size: 14px; color: var(--text-muted); line-height: 1.55; }
  .callout code {
    font-family: var(--mono);
    font-size: 0.88em;
    padding: 1px 6px;
    background: var(--code-bg);
    border-radius: 4px;
    color: var(--text);
  }

  @media (max-width: 880px) {
    .install-layout { grid-template-columns: 1fr; gap: 32px; }
    .install-row { grid-template-columns: auto 1fr auto auto; gap: 10px; padding: 9px 10px 9px 12px; }
    .install-cmd { font-size: 12.5px; }
    .install-tag { display: none; }
    .qs-list { font-size: 12.5px; }
  }
</style>
